class Solution:
    def getSecondLargest(self, arr):
        max1 = arr[0]
        max2 = float('-inf')

        for i in range(1, len(arr)):
            if arr[i] > max1:
                max2 = max1
                max1 = arr[i]
            elif max1 > arr[i] > max2:
                max2 = arr[i]

        return -1 if max2 == float('-inf') else max2

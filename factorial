class Solution {
  public:
    int factorial(int n) {
        // code here
        int sum=0;
        for (int i=n ; i> 0 ;i++)
        {
            sum+=i;
        }
        return sum;
    }
};

class Solution {
  public:
    int factorial(int n) {
        // code here
        if (n<2)
            return 1;
        return n*factorial(n-1);
        
    }
};
